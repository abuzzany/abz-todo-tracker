<%= form_with(model: completed_to_do_item) do |form| %>
  <% if completed_to_do_item.errors.any? %>
    <div style="color: red">
      <h2><%= pluralize(completed_to_do_item.errors.count, "error") %> prohibited this completed_to_do_item from being saved:</h2>

      <ul>
        <% completed_to_do_item.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
