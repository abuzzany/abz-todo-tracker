<%= form_with(model: to_do_item, class: "space-y-5") do |form| %>
  <% if to_do_item.errors.any? %>
    <div class="rounded-lg bg-red-50 px-4 py-3 text-sm text-red-800">
      <h2 class="mb-1 font-medium"><%= pluralize(to_do_item.errors.count, "error") %> prohibited this to_do_item from being saved:</h2>
      <ul class="list-disc pl-5">
        <% to_do_item.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= form.label :category, class: "mb-1.5 block text-sm font-medium text-gray-700" %>
    <%= form.text_field :category, placeholder: "e.g. Personal", class: "w-full rounded-lg border border-gray-200 bg-gray-50 px-3.5 py-2.5 text-sm text-gray-900 placeholder:text-gray-400 transition focus:border-gray-300 focus:bg-white focus:outline-none focus:ring-2 focus:ring-blue-500/20" %>
  </div>

  <div>
    <%= form.label :title, class: "mb-1.5 block text-sm font-medium text-gray-700" %>
    <%= form.text_field :title, placeholder: "What needs to be done?", class: "w-full rounded-lg border border-gray-200 bg-gray-50 px-3.5 py-2.5 text-sm text-gray-900 placeholder:text-gray-400 transition focus:border-gray-300 focus:bg-white focus:outline-none focus:ring-2 focus:ring-blue-500/20" %>
  </div>

  <div>
    <%= form.label :description, class: "mb-1.5 block text-sm font-medium text-gray-700" %>
    <%= form.textarea :description, rows: 3, placeholder: "Add any extra details (optional)", class: "w-full resize-none rounded-lg border border-gray-200 bg-gray-50 px-3.5 py-2.5 text-sm text-gray-900 placeholder:text-gray-400 transition focus:border-gray-300 focus:bg-white focus:outline-none focus:ring-2 focus:ring-blue-500/20" %>
  </div>

  <div class="flex items-center justify-between gap-4 rounded-lg border border-gray-200 bg-gray-50 px-3.5 py-2.5">
    <%= form.label :completed, class: "text-sm font-medium text-gray-700" %>
    <%= form.check_box :completed, class: "h-4 w-4 rounded border-gray-300 text-blue-600 focus:ring-blue-500/20" %>
  </div>

  <div>
    <%= form.label :completed_at, class: "mb-1.5 block text-sm font-medium text-gray-700" %>
    <%= form.date_field :completed_at, class: "w-full rounded-lg border border-gray-200 bg-gray-50 px-3.5 py-2.5 text-sm text-gray-900 transition focus:border-gray-300 focus:bg-white focus:outline-none focus:ring-2 focus:ring-blue-500/20" %>
  </div>

  <div class="pt-2">
    <%= form.submit class: "w-full cursor-pointer rounded-lg bg-blue-600 px-4 py-2.5 text-sm font-semibold text-white transition hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-blue-500/40" %>
  </div>
<% end %>
