<%= form_with(model: to_do_item) do |form| %>
  <% if to_do_item.errors.any? %>
    <div class="mb-4 rounded-md bg-red-50 px-4 py-3 text-sm text-red-800">
      <h2 class="mb-2 font-medium"><%= pluralize(to_do_item.errors.count, "error") %> prohibited this to_do_item from being saved:</h2>
      <ul class="list-disc pl-5">
        <% to_do_item.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="mb-4">
    <%= form.label :category, class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= form.text_field :category, class: "w-full rounded border border-gray-300 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500" %>
  </div>



  <div class="mb-4">
    <%= form.label :title, class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= form.text_field :title, class: "w-full rounded border border-gray-300 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500" %>
  </div>

  <div class="mb-4">
    <%= form.label :description, class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= form.textarea :description, class: "w-full rounded border border-gray-300 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500" %>
  </div>

  <div class="mb-4 flex items-center gap-2">
    <%= form.check_box :completed, class: "h-4 w-4 rounded border-gray-300 text-blue-600" %>
    <%= form.label :completed, class: "text-sm font-medium text-gray-700" %>
  </div>

  <div class="mb-4">
    <%= form.label :completed_at, class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= form.date_field :completed_at, class: "w-full rounded border border-gray-300 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500" %>
  </div>

  <div>
    <%= form.submit class: "rounded bg-blue-600 px-4 py-2 text-sm font-medium text-white hover:bg-blue-700 cursor-pointer" %>
  </div>
<% end %>
