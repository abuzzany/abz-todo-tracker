<% if notice.present? %>
  <p class="mb-4 rounded-md bg-green-50 px-4 py-2 text-sm text-green-800"><%= notice %></p>
<% end %>

<% content_for :title, "To do items" %>

<h1 class="mb-6 text-3xl font-bold text-gray-900">To do items</h1>

<div class="mb-6">
  <h2 class="mb-2 text-lg font-semibold text-gray-700">Completed tasks per day</h2>
  <%= line_chart @completed_chart_data %>
</div>

<div id="to_do_items" class="">
  <table class="table-fixed border-2 border-solid border-gray-300">
    <thead class="border-2 border-solid border-gray-300">
      <tr>
        <th class="w-1/5 px-4 py-3 text-left">Category</th>
        <th class="w-1/5 px-4 py-3 text-left">Title</th>
        <th class="w-2/5 px-4 py-3 text-left">Description</th>
        <th class="w-1/10 px-4 py-3 text-left">Completed</th>
        <th class="w-1/5 px-4 py-3 text-left">Completed at</th>
        <th class="w-1/10 px-4 py-3 text-left">Actions</th>
      </tr>
    </thead>
    <tbody class="">
      <% @to_do_items.each do |to_do_item| %>
        <tr id="<%= dom_id to_do_item %>" class="border-1 border-solid border-gray-300">
          <td class="px-4 py-3"><%= to_do_item.category %></td>
          <td class="px-4 py-3"><%= to_do_item.title %></td>
          <td class="px-4 py-3"><%= to_do_item.description %></td>
          <td class="px-4 py-3"><%= to_do_item.completed %></td>
          <td class="px-4 py-3"><%= to_do_item.completed_at %></td>
          <td class="px-4 py-3">
            <%= link_to "Show", to_do_item, class: "rounded-full bg-blue-100 px-3 py-1 text-sm font-medium text-blue-700 hover:bg-blue-200" %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>

<%= primary_button_to "New to do item", new_to_do_item_path, class: "mt-4 self-start inline-block" %>
