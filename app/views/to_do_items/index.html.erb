<% if notice.present? %>
  <p class="mb-4 rounded-md bg-green-50 px-4 py-2 text-sm text-green-800"><%= notice %></p>
<% end %>

<% content_for :title, "To do items" %>

<h1 class="mb-6 text-3xl font-bold text-gray-900">To do items</h1>

<div id="to_do_items" class="">
  <table class="">
    <thead class="">
      <tr>
        <th class="">Title</th>
        <th class="">Description</th>
        <th class="">Completed</th>
        <th class="">Completed at</th>
        <th class="">Actions</th>
      </tr>
    </thead>
    <tbody class="">
      <% @to_do_items.each do |to_do_item| %>
        <tr id="<%= dom_id to_do_item %>" class="">
          <td class=""><%= to_do_item.title %></td>
          <td class=""><%= to_do_item.description %></td>
          <td class=""<%= to_do_item.completed %></td>
          <td class=""><%= to_do_item.completed_at %></td>
          <td class="">
            <%= link_to "Show", to_do_item, class: "" %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>

<%= link_to "New to do item", new_to_do_item_path,
      class: "" %>
